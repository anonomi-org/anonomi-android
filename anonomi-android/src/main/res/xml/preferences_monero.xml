<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto">

	<PreferenceCategory
		android:layout="@layout/preferences_category"
		android:title="@string/pref_category_monero_wallet">

		<EditTextPreference
			android:key="pref_key_primary_address"
			android:title="@string/pref_primary_address_title"
			android:hint="@string/pref_primary_address_hint"
			android:inputType="text"
			app:iconSpaceReserved="false"
			app:singleLineTitle="false"
			app:useSimpleSummaryProvider="true" />

		<EditTextPreference
			android:key="pref_key_private_view_key"
			android:title="@string/pref_private_view_key_title"
			android:hint="@string/pref_private_view_key_hint"
			android:inputType="text"
			app:iconSpaceReserved="false"
			app:singleLineTitle="false"
			app:useSimpleSummaryProvider="true" />

	</PreferenceCategory>

	<PreferenceCategory
		android:layout="@layout/preferences_category"
		android:title="@string/pref_category_monero_config"
		app:allowDividerAbove="true">

		<EditTextPreference
			android:key="pref_key_monero_rate"
			android:title="@string/pref_monero_rate_title"
			android:hint="@string/pref_monero_rate_hint"
			android:inputType="numberDecimal"
			app:iconSpaceReserved="false"
			app:singleLineTitle="false"
			app:useSimpleSummaryProvider="true" />

		<EditTextPreference
			android:key="pref_key_minor_index_key"
			android:title="@string/pref_minor_index_title"
			android:hint="@string/pref_minor_index_hint"
			android:inputType="number"
			app:iconSpaceReserved="false"
			app:singleLineTitle="false"
			app:useSimpleSummaryProvider="true" />

	</PreferenceCategory>

</PreferenceScreen>
